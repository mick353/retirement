{
  "name": "robinson-retirement",
  "displayName": "Robinson Retirement Command Centre",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite --config vite.pages.config.ts",
    "dev:pages": "vite --config vite.pages.config.ts",
    "typecheck": "tsc --noEmit --project tsconfig.pages.json",
    "build": "npm run build:pages",
    "build:pages": "vite build --config vite.pages.config.ts",
    "preview": "vite preview --config vite.pages.config.ts",
    "preview:pages": "vite preview --config vite.pages.config.ts"
  },
  "dependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vite": "8.0.13"
  },
  "type": "module"
}
